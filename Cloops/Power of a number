// Power of a number without using pow() function
#include <stdio.h>

int main()
{
    int  base, exponent;
    printf("Enter base and exponent respectively: ");
    scanf("%d %d", &base, &exponent);

    int result = 1;
    for (int i = 0; i < exponent; i++)
    {
        result *= base;
    }
    printf("Result: %d", result);
    return 0;
}
