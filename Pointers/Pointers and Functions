// Call by value and call by reference
#include <stdio.h>

void callByValue(int a) {
    a = a + 10; // This change will not affect the original variable
}

void callByReference(int *a) {
    *a = *a + 10; // This change will affect the original variable
}
int main() {
    int num1 = 5;
    int num2 = 5;

    printf("Before callByValue: num1 = %d\n", num1);
    callByValue(num1);
    printf("After callByValue: num1 = %d\n", num1); // num1 remains unchanged

    printf("Before callByReference: num2 = %d\n", num2);
    callByReference(&num2);
    printf("After callByReference: num2 = %d\n", num2); // num2 is changed

    return 0;
}
